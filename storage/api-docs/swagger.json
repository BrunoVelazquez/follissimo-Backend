{
    "openapi": "3.0.0",
    "info": {
        "title": "Folissimo API",
        "description": "Descripción de la API",
        "version": "1.0.0"
    },
    "paths": {
        "/rest/categorias": {
            "get": {
                "tags": [
                    "Categorias"
                ],
                "summary": "Obtener lista de categorías",
                "description": "Obtiene la lista de todas las categorias",
                "operationId": "getCategoriasList",
                "responses": {
                    "200": {
                        "description": "Operación exitosa"
                    },
                    "404": {
                        "description": "No se encontraron categorias"
                    }
                }
            }
        },
        "/rest/compra": {
            "post": {
                "tags": [
                    "Compra"
                ],
                "summary": "Crear una nueva compra",
                "description": "Realizar una compra.",
                "operationId": "store",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "monto_total",
                                    "detalle_productos"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string"
                                    },
                                    "monto_total": {
                                        "type": "integer"
                                    },
                                    "detalle_productos": {
                                        "type": "array",
                                        "items": {
                                            "properties": {
                                                "id_producto": {
                                                    "type": "integer"
                                                },
                                                "cantidad": {
                                                    "type": "integer"
                                                },
                                                "monto_subtotal": {
                                                    "type": "integer"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Operación exitosa"
                    },
                    "422": {
                        "description": "Parámetros incorrectos"
                    }
                }
            }
        },
        "/rest/pedidos/{id_pedido}/detalle": {
            "get": {
                "tags": [
                    "Detalle de Pedido"
                ],
                "summary": "Obtener un detalle de pedido",
                "description": "Obtiene la información de un detalle de pedido en base a su ID.",
                "operationId": "DetallePedidoShow",
                "parameters": [
                    {
                        "name": "id_pedido",
                        "in": "path",
                        "description": "ID del pedido",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Información del detalle de pedido"
                    },
                    "404": {
                        "description": "Detalle de pedido no encontrado"
                    }
                }
            }
        },
        "/rest/pedidos/{email}": {
            "get": {
                "tags": [
                    "Pedido"
                ],
                "summary": "Obtener pedidos de un cliente",
                "description": "Obtiene la lista de pedidos asociados a un cliente en base a su ID.",
                "operationId": "pedidoIndexID",
                "parameters": [
                    {
                        "name": "email",
                        "in": "path",
                        "description": "Email del cliente",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Lista de pedidos del cliente"
                    },
                    "404": {
                        "description": "No se encontraron pedidos del cliente"
                    }
                }
            }
        },
        "/rest/pedidos/cancelar": {
            "put": {
                "tags": [
                    "Pedido"
                ],
                "summary": "Cancelar un pedido",
                "description": "Cancela un pedido en base a su ID.",
                "operationId": "pedidoCancelar",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "id_pedido"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string"
                                    },
                                    "id_pedido": {
                                        "type": "integer"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Pedido cancelado exitosamente"
                    },
                    "404": {
                        "description": "Pedido/Cliente no encontrado"
                    },
                    "422": {
                        "description": "Pedido ya fue cancelado/entregado"
                    }
                }
            }
        },
        "/rest/productos": {
            "get": {
                "tags": [
                    "Productos"
                ],
                "summary": "Obtener lista de productos",
                "description": "Obtiene la lista de todos los productos.",
                "operationId": "getProductosList",
                "responses": {
                    "200": {
                        "description": "Operación exitosa"
                    },
                    "404": {
                        "description": "Productos no encontrados"
                    }
                }
            }
        },
        "/rest/productos/tamaño/{tipo_tamaño}": {
            "get": {
                "tags": [
                    "Productos"
                ],
                "summary": "Obtener productos por tamaño",
                "description": "Muestra todos los productos filtrados por un tamaño dado",
                "operationId": "getproductosPorTamaño",
                "parameters": [
                    {
                        "name": "tipo_tamaño",
                        "in": "path",
                        "description": "Tipo de tamaño",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Operación exitosa"
                    },
                    "404": {
                        "description": "Productos no encontrados"
                    }
                }
            }
        },
        "/rest/productos/categoria/{tipo_categoria}": {
            "get": {
                "tags": [
                    "Productos"
                ],
                "summary": "Obtener productos por categoría",
                "description": "Muestra todos los productos filtrados por una categoria dada",
                "operationId": "getproductosPorCategoria",
                "parameters": [
                    {
                        "name": "tipo_categoria",
                        "in": "path",
                        "description": "Tipo de categoría",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Operación exitosa"
                    },
                    "404": {
                        "description": "Productos no encontrados"
                    }
                }
            }
        },
        "/rest/productos/{id}": {
            "get": {
                "tags": [
                    "Producto"
                ],
                "summary": "Obtener información de un producto",
                "description": "Obtiene la información de un producto en base a su ID.",
                "operationId": "productoShow",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID del producto",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Información del producto"
                    },
                    "404": {
                        "description": "Producto no encontrado"
                    }
                }
            }
        },
        "/rest/tamaños": {
            "get": {
                "tags": [
                    "Tamaños"
                ],
                "summary": "Obtener lista de tamaños",
                "description": "Obtiene la lista de todos los tamaños",
                "operationId": "getTamañosList",
                "responses": {
                    "200": {
                        "description": "Operación exitosa"
                    },
                    "404": {
                        "description": "No se encontraron tamaños"
                    }
                }
            }
        }
    }
}
